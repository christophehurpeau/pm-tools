{
  "name": "pnpm-dedup",
  "version": "2.0.0",
  "description": "List duplicates and dedupe pnpm lock file",
  "keywords": [
    "dedupe",
    "duplicate",
    "pnpm"
  ],
  "homepage": "https://github.com/christophehurpeau/pm-tools",
  "bugs": {
    "url": "https://github.com/christophehurpeau/pnpm-dedup/issues"
  },
  "license": "ISC",
  "author": "Christophe Hurpeau <christophe@hurpeau.com> (https://christophe.hurpeau.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/christophehurpeau/pm-tools.git",
    "directory": "packages/pnpm-dedup"
  },
  "bin": {
    "pnpm-dedup": "./src/bin/pnpm-dedupe.ts",
    "pnpm-dedupe": "./src/bin/pnpm-dedupe.ts",
    "pnpm-why-duplicate": "./src/bin/pnpm-why-duplicate.ts"
  },
  "files": [
    "src",
    "dist",
    "bin"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/definitions/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    "./src/index": {
      "types": "./dist/definitions/src/index.d.ts",
      "node": {
        "import": "./dist/src/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "bun run lint:eslint",
    "lint:eslint": "bun run --cwd '../..' eslint --quiet 'packages/pnpm-dedup'",
    "test": "bun run --cwd '../..' test -- 'packages/pnpm-dedup'",
    "tsc": "tsc"
  },
  "dependencies": {
    "picomatch": "4.0.4",
    "pm-utils": "workspace:*",
    "semver": "7.6.0",
    "tslib": "2.8.1",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/picomatch": "4.0.3",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "pob": {
    "bundler": "tsc",
    "entries": [
      "src/index.ts"
    ]
  }
}
