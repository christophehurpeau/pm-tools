{
  "extends": [
    "@pob/root/tsconfigs/strict.json",
    "@pob/root/tsconfigs/targets/node-22.json"
  ],
  "include": ["src/**/*.ts"],
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declarationDir": "dist/definitions",
    "tsBuildInfoFile": "node_modules/.cache/tsc/tsbuildinfo",
    "noEmitOnError": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "incremental": true,
    "composite": true,
    "allowImportingTsExtensions": true,

    "paths": {
      "pm-utils": ["../../packages/pm-utils/src"],
      "pm-utils/*": ["../../packages/pm-utils/src/*"]
    }
  },
  "references": [{ "path": "../../packages/pm-utils/tsconfig.json" }]
}
