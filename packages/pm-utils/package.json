{
  "name": "pm-utils",
  "version": "0.0.0",
  "description": "package manager utils",
  "keywords": [],
  "homepage": "https://github.com/christophehurpeau/pm-tools",
  "license": "MIT",
  "author": "Christophe Hurpeau <christophe@hurpeau.com> (https://christophe.hurpeau.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/christophehurpeau/pm-tools.git",
    "directory": "packages/pm-utils"
  },
  "files": [
    "src",
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/definitions/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/definitions/index.d.ts",
      "node": {
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "bun run lint:eslint",
    "lint:eslint": "bun run --cwd '../..' eslint --quiet 'packages/pm-utils'",
    "test": "bun run --cwd '../..' test -- 'packages/pm-utils'",
    "tsc": "tsc"
  },
  "dependencies": {
    "semver": "7.6.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "pob": {
    "bundler": "tsc",
    "entries": [
      "index"
    ],
    "envs": [
      {
        "target": "node",
        "version": "22"
      }
    ]
  }
}
