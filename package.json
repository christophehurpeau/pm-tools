{
  "name": "pm-tools-monorepo",
  "version": "2.0.0",
  "private": true,
  "homepage": "https://github.com/christophehurpeau/pm-tools",
  "license": "ISC",
  "author": "Christophe Hurpeau <christophe@hurpeau.com> (https://christophe.hurpeau.com)",
  "repository": "https://github.com/christophehurpeau/pm-tools.git",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run build:definitions",
    "build:definitions": "tsc -b",
    "checks": "node scripts/check-packages.js",
    "format": "oxfmt",
    "format:check": "oxfmt --check .",
    "lint": "bun run format && bun run lint:eslint",
    "lint:eslint": "eslint --quiet .",
    "lint:prettier": "pob-root-prettier --check .",
    "lint:prettier:fix": "pob-root-prettier --write .",
    "prepare": "pob-root-postinstall",
    "test": "TZ=UTC bun test",
    "test:coverage": "TZ=UTC bun test --coverage ",
    "test:coverage:json": "TZ=UTC bun test --coverage --coverage-report=json",
    "test:watch": "TZ=UTC bun test --watch",
    "tsc": "tsc -b"
  },
  "devDependencies": {
    "@pob/eslint-config": "65.6.0",
    "@pob/root": "24.2.1",
    "check-package-dependencies": "11.1.1",
    "eslint": "10.4.0",
    "typescript": "6.0.3"
  },
  "commitlint": {
    "extends": [
      "@pob/root/commitlint-config"
    ]
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
